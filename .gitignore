```gitignore
# Python cache files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# IDE files
.idea/
.vscode/
*.iml

# Operating system files
.DS_Store
Thumbs.db

# Environment variables and secrets
.env
.env.*
*.key

# Raw and input datasets
data/raw/
data/input/

# Generated processed outputs
data/processed/

# Generated embeddings
data/embeddings/

# Keep empty data folders if .gitkeep files are used
!data/
!data/input/.gitkeep
!data/processed/.gitkeep
!data/raw/.gitkeep
!data/embeddings/.gitkeep

# Model and library caches
.cache/
huggingface/
sentence_transformers/
models/

# Logs
*.log

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Testing and coverage files
.pytest_cache/
.coverage
htmlcov/

# Build and packaging files
build/
dist/
*.egg-info/
```